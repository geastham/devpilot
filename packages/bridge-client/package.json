{
  "name": "@devpilot/bridge-client",
  "version": "0.1.0",
  "description": "DevPilot Bridge Client - Local orchestrator connection to cloud bridge",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",

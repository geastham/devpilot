# Database
DATABASE_URL="postgresql://user:password@localhost:5432/devpilot?schema=public"
DEVPILOT_SQLITE_PATH=".devpilot/data.db"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Wave Planner Configuration
WAVE_PLANNER_ENABLED=true
WAVE_PLANNER_MAX_CONCURRENCY=4
WAVE_PLANNER_MAX_TOTAL_ACTIVE=8
WAVE_PLANNER_DISPATCH_DELAY_MS=500
WAVE_PLANNER_ADVANCE_DELAY_MS=2000
WAVE_PLANNER_RETRY_LIMIT=1
WAVE_PLANNER_FAILURE_POLICY=halt
WAVE_PLANNER_AUTO_ADVANCE=true
WAVE_PLANNER_MIN_PARALLELIZATION=0.3
WAVE_PLANNER_MODEL=claude-sonnet-4-20250514
WAVE_PLANNER_MAX_TOKENS=8192

# Anthropic API (for wave plan generation)
ANTHROPIC_API_KEY=your-api-key-here